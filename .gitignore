# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# uploaded images (user uploads ignored, static assets whitelisted)
public/uploads/*
!public/uploads/.gitkeep
!public/uploads/qr.jpeg
!public/uploads/exchange.jpg
!public/uploads/education.jpg
!public/uploads/food.avif

# typescript
*.tsbuildinfo
next-env.d.ts
